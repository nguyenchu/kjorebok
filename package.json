{
  "name": "kjorebok",
  "private": true,
  "scripts": {
    "dev": "./run-local.sh",
    "dev:api": "corepack pnpm --filter @kjorebok/api dev",
    "dev:web": "corepack pnpm --filter @kjorebok/web dev",
    "dev:mobile": "corepack pnpm --filter @kjorebok/mobile dev",
    "dev:mobile:device": "corepack pnpm --filter @kjorebok/mobile android:device:server",
    "build": "turbo build",
    "lint": "turbo lint",
    "test:mobile:maestro": "maestro test .maestro/tests",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:migrate": "turbo db:migrate",
    "db:generate": "turbo db:generate",
    "db:studio": "corepack pnpm --filter @kjorebok/api db:studio",
    "mobile:bump": "node scripts/bump-mobile.mjs"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.32.1"
}
