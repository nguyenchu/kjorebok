{
  "name": "kjorebok",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:local": "./run-local.sh",
    "dev:mobile": "corepack pnpm --filter @kjorebok/mobile dev",
    "dev:mobile:android": "corepack pnpm --filter @kjorebok/mobile android",
    "dev:mobile:android:device": "corepack pnpm --filter @kjorebok/mobile android:device",
    "dev:mobile:android:local": "corepack pnpm --filter @kjorebok/mobile android:device:local",
    "dev:mobile:android:server": "corepack pnpm --filter @kjorebok/mobile android:device:server",
    "dev:api": "corepack pnpm --filter @kjorebok/api dev",
    "dev:web": "corepack pnpm --filter @kjorebok/web dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.32.1"
}
